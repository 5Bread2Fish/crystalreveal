// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("POSTGRES_PRISMA_URL") // Uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // Uses direct connection
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  password          String
  userType          String   // INDIVIDUAL, BUSINESS
  credits           Int      @default(0)
  creditExpiresAt   DateTime?
  businessName      String?
  ownerName         String?
  phoneNumber       String?
  pregnancyWeeks    String?
  monthlyScanVolume String?
  website           String?
  country           String?
  city              String?    // Added for geolocation
  ipAddress         String?    // Added for geolocation
  marketingAgreed   Boolean  @default(true)
  marketingAgreedAt DateTime?
  status            String   @default("active") // active, deleted
  lastLoginAt       DateTime?
  deletedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  images       ImageGeneration[]
  transactions CreditTransaction[]
  deletionNotifications DeletedAccountNotification[]
}

model ImageGeneration {
  id              String   @id @default(cuid())
  userId          String?
  sessionId       String?  // For guest users
  originalUrl     String?
  basicUrl        String?
  advancedUrl     String? 
  unlocked        Boolean  @default(false)
  unlockedAt      DateTime?
  ip              String?
  country         String?
  city            String?  // Added for geolocation
  basicRating     Int?     // 1-5 stars
  advancedRating  Int?     // 1-5 stars
  isFeatured      Boolean  @default(false)
  createdAt       DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model CreditTransaction {
  id             String   @id @default(cuid())
  userId         String
  amountPaid     Decimal
  subtotal       Decimal? // Original amount before discount
  discountAmount Decimal? // Discounted amount
  couponCode     String?  // Code used
  creditsChange  Int
  transactionType String // PURCHASE, USE, BONUS, EXPIRATION, FREE_PROMOTION
  stripeChargeId String?
  expiresAt      DateTime? // When credits from this purchase expire
  isExpired      Boolean  @default(false)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model PromotionSettings {
  id              String   @id @default(cuid())
  freeUnlockMode  Boolean  @default(false)
  updatedAt       DateTime @updatedAt
  updatedBy       String?  // Admin identifier
}

model DeletedAccountNotification {
  id              String   @id @default(cuid())
  userId          String
  userEmail       String
  userType        String
  businessName    String?
  deletedAt       DateTime @default(now())
  imageCount      Int      @default(0)
  creditBalance   Int      @default(0)
  
  user User @relation(fields: [userId], references: [id])
}
